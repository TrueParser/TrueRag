{
    "Logging":  {
                    "LogLevel":  {
                                     "Default":  "Information",
                                     "Microsoft.AspNetCore":  "Warning"
                                 }
                },
    "ConnectionStrings":  {
                              "DbWrite":  "Host=localhost;Port=5432;Database=truerag_write;Username=truerag;Password=truerag",
                              "DbRead":  "Host=localhost;Port=5432;Database=truerag_read;Username=truerag;Password=truerag",
                              "Redis":  "",
                              "Nats":  ""
                          },
    "RetrievalEngine":  {
                            "RequireHighFidelity":  false,
                            "FallbackToStandardRag":  true,
                            "EnableMultiHopLinking":  true,
                            "MultiHopMaxNodes":  16,
                            "EnableStructuralDiffing":  true,
                            "StructuralDiffMaxRequests":  4,
                            "EnableSemanticCache":  true,
                            "SemanticCacheTtl":  "00:02:00",
                            "EnableDistributedRateLimit":  false,
                            "DistributedRateLimitRequests":  120,
                            "DistributedRateLimitWindow":  "00:01:00",
                            "RetrievalConfidenceWeight":  0.7,
                            "LlmCertaintyWeight":  0.3
                        },
    "LlmProvider":  {
                        "DefaultProvider":  "local"
                    },
    "PromptAssembly":  {
                           "DefaultTokenBudget":  3000,
                           "ReservedCompletionTokens":  700,
                           "SystemInstruction":  "Answer only from provided context. If context is insufficient, explicitly say so."
                       },
    "GroundingGovernance":  {
                               "MinimumRetrievalConfidence":  0.45,
                               "MinimumEvidenceCoverage":  0.75,
                               "RequireCitationCompleteness":  true,
                               "AllowPartialAnswer":  true,
                               "MinimumCoverageForPartialAnswer":  0.4,
                               "ConflictPolicy":  "SummarizeDisagreement",
                               "EnableVerifierPass":  true,
                               "VerifierMaxAttempts":  1,
                               "VerifierMaxElapsedMs":  800,
                               "MemoryCitationPolicy":  "NonCiteable"
                           },
    "RequestContext":  {
                           "TenantHeaderName":  "X-Tenant-Id",
                           "AppHeaderName":  "X-App-Id",
                           "CollectionHeaderName":  "X-Collection-Id",
                           "TenantClaimType":  "tenant_id",
                           "AppClaimType":  "app_id",
                           "CollectionClaimType":  "collection_id",
                           "CollectionIdPattern":  "^[a-zA-Z0-9._:-]{1,128}$",
                           "EnableCollectionScopeAuthorization":  true,
                           "UserIdClaimType":  "sub",
                           "RoleClaimType":  "role",
                           "AllowedDocumentGroupClaimType":  "allowed_document_group"
                       },
    "IngestionRuntime":  {
                             "NodeId":  "node-1",
                             "WalRootPath":  "wal",
                             "SyncMaxConcurrency":  8,
                             "WalFsync":  false,
                             "WalMaxSegmentBytes":  67108864,
                             "WorkerBatchSize":  16,
                             "WorkerBatchWaitMs":  200
                         },
    "IngestionFidelity":  {
                              "DefaultMode":  "auto",
                              "AllowExplicitOverride":  true
                          },
    "IngestionBackpressure":  {
                                  "MaxFamilyQueueDepth":  1024,
                                  "DrainCapacityRatioRejectThreshold":  1.4,
                                  "MinDepthBeforeDrainRatioReject":  32,
                                  "MinSampleWindowSeconds":  5
                              },
    "ResourceGuard":  {
                          "Enabled":  true,
                          "SampleIntervalMs":  1000,
                          "MemoryDegradedPercent":  75,
                          "MemoryOverloadedPercent":  90,
                          "CpuDegradedPercent":  75,
                          "CpuOverloadedPercent":  90,
                          "ThreadPoolQueuePerCoreDegradedThreshold":  20,
                          "ThreadPoolQueuePerCoreOverloadedThreshold":  50,
                          "ActiveRequestsDegradedThreshold":  500,
                          "ActiveRequestsOverloadedThreshold":  1000,
                          "DrainCapacityRatioDegradedThreshold":  1.3,
                          "DrainCapacityRatioOverloadedThreshold":  1.8,
                          "LiveQueueDepthDegradedThreshold":  256,
                          "LiveQueueDepthOverloadedThreshold":  1024,
                          "ConsecutiveSamplesForOverload":  2,
                          "ConsecutiveSamplesForRecovery":  3,
                          "MinimumOverloadedDurationMs":  1500,
                          "RetryAfterOverloadedSeconds":  15,
                          "BypassPaths":  [
                                              "/health/live",
                                              "/health/ready"
                                          ]
                      },
    "Queue":  {
                  "Url":  "nats://localhost:4222",
                  "StreamName":  "TrueRagJob",
                  "SubjectPrefix":  "TrueRAG.Job",
                  "IngestSubjectBase":  "TrueRAG.Job.Ingest"
              },
    "Embeddings":  {
                       "Onnx":  {
                                    "ProviderName":  "onnx",
                                    "MaxBatchSize":  16,
                                    "InferenceTimeoutSeconds":  15,
                                    "EnableWarmup":  false,
                                    "WarmupTimeoutSeconds":  10,
                                    "ModelArtifactsPath":  "models/onnx/bge-small-en-v1.5",
                                    "ModelFileName":  "model.onnx"
                                },
                       "ProfileSelection":  {
                                                "DefaultProfileName":  "bge-small-en-v1.5",
                                                "ExpectedVectorDimensions":  384,
                                                "ScopedProfiles":  [

                                                                   ],
                                                "ExpectedVectorMaxTokens":  512,
                                                "AllowGlobalPathFallback":  true
                                            },
                       "OpenAI":  {
                                      "Enabled":  false,
                                      "ProviderName":  "openai",
                                      "ApiKey":  "",
                                      "Endpoint":  "https://api.openai.com/v1/embeddings",
                                      "Model":  "text-embedding-3-small",
                                      "Dimensions":  1536,
                                      "MaxTokens":  8192,
                                      "Resilience":  {
                                                         "TimeoutSeconds":  15,
                                                         "MaxRetries":  2,
                                                         "BaseDelayMilliseconds":  200,
                                                         "MaxJitterMilliseconds":  100
                                                     }
                                  },
                       "ModeSelection":  {
                                             "DefaultMode":  "internal_embedding",
                                             "ScopedModes":  [

                                                             ]
                                         }
                   }
}
