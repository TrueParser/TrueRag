{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "CrateDbWrite": "Host=localhost;Port=5432;Database=truerag_write;Username=truerag;Password=truerag",
    "CrateDbRead": "Host=localhost;Port=5432;Database=truerag_read;Username=truerag;Password=truerag",
    "Redis": "",
    "Nats": ""
  },
  "RetrievalEngine": {
    "RequireHighFidelity": false,
    "FallbackToStandardRag": true
  },
  "RequestContext": {
    "TenantHeaderName": "X-Tenant-Id",
    "AppHeaderName": "X-App-Id",
    "TenantClaimType": "tenant_id",
    "AppClaimType": "app_id",
    "UserIdClaimType": "sub",
    "RoleClaimType": "role",
    "AllowedDocumentGroupClaimType": "allowed_document_group"
  },
  "IngestionRuntime": {
    "NodeId": "node-1",
    "WalRootPath": "wal",
    "SyncMaxConcurrency": 8,
    "WalFsync": false,
    "WalMaxSegmentBytes": 67108864,
    "WorkerBatchSize": 16,
    "WorkerBatchWaitMs": 200
  },
  "IngestionFidelity": {
    "DefaultMode": "auto",
    "AllowExplicitOverride": true
  },
  "Queue": {
    "Url": "nats://localhost:4222",
    "StreamName": "TrueRagJob",
    "SubjectPrefix": "TrueRAG.Job"
  }
}

